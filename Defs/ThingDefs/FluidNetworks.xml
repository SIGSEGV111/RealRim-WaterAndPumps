<Defs>
	<ThingDef ParentName="DubsDirtyPipeBase" Name="RealRim_FreshWaterPipe">
		<thingClass>Building</thingClass>
		<defName>RealRim_FreshWaterPipe</defName>
		<label>fresh-water pipe</label>
		<description>Pipe carrying cold fresh water at approximately 12 °C.</description>
		<designationCategory>Hygiene</designationCategory>
		<uiIconPath>DBH/UI/Plumbing</uiIconPath>
		<graphicData>
			<texPath>DBH/Things/Building/SewagePipe_Atlas</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<color>(0.35,0.70,1.00)</color>
			<linkType>Basic</linkType>
			<linkFlags><li>Custom1</li></linkFlags>
		</graphicData>
		<stuffCategories><li>Metallic</li><li>RealRim_PipePlastic</li></stuffCategories><costStuffCount>1</costStuffCount><researchPrerequisites><li>Plumbing</li></researchPrerequisites>
