	<ThingDef ParentName="DubsDirtyPipeBase" Name="RealRim_HeatingPipe">
		<thingClass>Building</thingClass>
		<defName>RealRim_HeatingPipe</defName>
		<label>heating pipe</label>
		<description>Insulated closed-loop supply-and-return pipe connecting heat sources, thermal tanks, radiators and pools. Each metre exchanges heat with outdoor air at 0.70 W/K and contributes 2 L of virtual heating-water buffer volume.</description>
		<designationCategory>Temperature</designationCategory>
		<uiIconPath>DBH/UI/Plumbing</uiIconPath>
		<graphicData>
			<texPath>DBH/Things/Building/SewagePipe_Atlas</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<color>(1.00,0.58,0.20)</color>
			<linkType>Basic</linkType>
			<linkFlags><li>Custom3</li></linkFlags>
		</graphicData>
		<stuffCategories><li>Metallic</li><li>RealRim_PipePlastic</li></stuffCategories><costStuffCount>1</costStuffCount><researchPrerequisites><li>CentralHeating</li></researchPrerequisites>
		<placeWorkers Inherit="False"><li>RealRim.WaterAndPumps.PlaceWorker_FluidPipe</li></placeWorkers>
	</ThingDef>
	<ThingDef ParentName="RealRim_HeatingPipe">
		<defName>RealRim_HeatingPipeHidden</defName>
		<label>heating pipe (hidden)</label>
		<graphicData><color>(0,0,0,0)</color><shaderType>Transparent</shaderType></graphicData>
		<statBases><MaxHitPoints>160</MaxHitPoints><WorkToBuild>2000</WorkToBuild><Flammability>0</Flammability><Beauty>0</Beauty></statBases>
