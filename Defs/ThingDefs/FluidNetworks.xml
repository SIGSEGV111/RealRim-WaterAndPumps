<?xml version='1.0' encoding='UTF-8'?>
<Defs>
	<ThingDef ParentName="DubsDirtyPipeBase" Name="RealRim_FreshWaterPipe">
		<thingClass>Building</thingClass>
		<defName>RealRim_FreshWaterPipe</defName>
		<label>fresh-water pipe</label>
		<description>Pipe carrying cold fresh water at approximately 12 °C.</description>
		<designationCategory>Hygiene</designationCategory>
		<uiIconPath>DBH/UI/Plumbing</uiIconPath>
		<graphicData>
			<texPath>DBH/Things/Building/SewagePipe_Atlas</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<color>(0.35,0.70,1.00)</color>
			<linkType>Basic</linkType>
			<linkFlags><li>Custom1</li></linkFlags>
		</graphicData>
		<costList><Steel>1</Steel></costList><researchPrerequisites><li>Plumbing</li></researchPrerequisites>
		<placeWorkers Inherit="False"><li>RealRim.WaterAndPumps.PlaceWorker_FluidPipe</li></placeWorkers>
	</ThingDef>
	<ThingDef ParentName="RealRim_FreshWaterPipe">
		<defName>RealRim_FreshWaterPipeHidden</defName>
		<label>fresh-water pipe (hidden)</label>
		<graphicData><color>(0,0,0,0)</color><shaderType>Transparent</shaderType></graphicData>
		<statBases><MaxHitPoints>100</MaxHitPoints><WorkToBuild>290</WorkToBuild><Flammability>0</Flammability><Beauty>0</Beauty></statBases>
	</ThingDef>

	<ThingDef ParentName="DubsDirtyPipeBase" Name="RealRim_HotWaterPipe">
		<thingClass>Building</thingClass>
		<defName>RealRim_HotWaterPipe</defName>
		<label>hot-water pipe</label>
		<description>Insulated pipe carrying domestic hot water from thermal storage to sinks, showers and baths. Each metre exchanges heat with outdoor air at 0.35 W/K.</description>
		<designationCategory>Hygiene</designationCategory>
		<uiIconPath>DBH/UI/Plumbing</uiIconPath>
		<graphicData>
			<texPath>DBH/Things/Building/SewagePipe_Atlas</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<color>(0.85,0.20,0.15)</color>
			<linkType>Basic</linkType>
			<linkFlags><li>Custom2</li></linkFlags>
		</graphicData>
		<costList><Steel>1</Steel></costList><researchPrerequisites><li>Plumbing</li></researchPrerequisites>
		<placeWorkers Inherit="False"><li>RealRim.WaterAndPumps.PlaceWorker_FluidPipe</li></placeWorkers>
	</ThingDef>
	<ThingDef ParentName="RealRim_HotWaterPipe">
		<defName>RealRim_HotWaterPipeHidden</defName>
		<label>hot-water pipe (hidden)</label>
		<graphicData><color>(0,0,0,0)</color><shaderType>Transparent</shaderType></graphicData>
		<statBases><MaxHitPoints>100</MaxHitPoints><WorkToBuild>290</WorkToBuild><Flammability>0</Flammability><Beauty>0</Beauty></statBases>
	</ThingDef>

	<ThingDef ParentName="DubsDirtyPipeBase" Name="RealRim_HeatingPipe">
		<thingClass>Building</thingClass>
		<defName>RealRim_HeatingPipe</defName>
		<label>heating pipe</label>
		<description>Insulated closed-loop supply-and-return pipe connecting heat sources, thermal tanks, radiators and pools. Each metre exchanges heat with outdoor air at 0.70 W/K.</description>
		<designationCategory>Temperature</designationCategory>
		<uiIconPath>DBH/UI/Plumbing</uiIconPath>
		<graphicData>
			<texPath>DBH/Things/Building/SewagePipe_Atlas</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<color>(1.00,0.58,0.20)</color>
			<linkType>Basic</linkType>
			<linkFlags><li>Custom3</li></linkFlags>
		</graphicData>
		<costList><Steel>1</Steel></costList><researchPrerequisites><li>CentralHeating</li></researchPrerequisites>
		<placeWorkers Inherit="False"><li>RealRim.WaterAndPumps.PlaceWorker_FluidPipe</li></placeWorkers>
	</ThingDef>
	<ThingDef ParentName="RealRim_HeatingPipe">
		<defName>RealRim_HeatingPipeHidden</defName>
		<label>heating pipe (hidden)</label>
		<graphicData><color>(0,0,0,0)</color><shaderType>Transparent</shaderType></graphicData>
		<statBases><MaxHitPoints>100</MaxHitPoints><WorkToBuild>290</WorkToBuild><Flammability>0</Flammability><Beauty>0</Beauty></statBases>
	</ThingDef>

	<ThingDef ParentName="BuildingBase" Name="RealRim_FluidValveBase" Abstract="True">
		<thingClass>Building</thingClass>
		<altitudeLayer>Building</altitudeLayer>
		<passability>Standable</passability>
		<minifiedDef>MinifiedThing</minifiedDef>
		<size>(1,1)</size>
		<rotatable>false</rotatable>
		<graphicData><texPath>DBH/Things/Building/Valve</texPath><graphicClass>Graphic_Single</graphicClass></graphicData>
		<statBases><MaxHitPoints>80</MaxHitPoints><WorkToBuild>350</WorkToBuild><Mass>2</Mass></statBases>
		<costList><Steel>15</Steel></costList>
		<building><isEdifice>false</isEdifice></building>
		<comps><li Class="CompProperties_Flickable"/></comps>
	</ThingDef>
	<ThingDef ParentName="RealRim_FluidValveBase"><defName>RealRim_FreshWaterValve</defName><label>fresh-water valve</label><designationCategory>Hygiene</designationCategory></ThingDef>
	<ThingDef ParentName="RealRim_FluidValveBase"><defName>RealRim_HotWaterValve</defName><label>hot-water valve</label><designationCategory>Hygiene</designationCategory></ThingDef>
	<ThingDef ParentName="RealRim_FluidValveBase"><defName>RealRim_HeatingValve</defName><label>heating valve</label><designationCategory>Temperature</designationCategory></ThingDef>
	<ThingDef ParentName="RealRim_FluidValveBase"><defName>RealRim_CoolantValve</defName><label>coolant valve</label><designationCategory>Temperature</designationCategory></ThingDef>

	<ThingDef ParentName="RealRim_FluidValveBase">
		<defName>RealRim_SmartMixingValve</defName>
		<label>smart mixing valve</label>
		<description>A powered thermostatic hydronic mixing valve for heating-water circuits. It keeps two adjacent heating circuits separate, draws heat from the hotter source side, and mixes it into the receiving side until the selected receiving-network temperature is reached or the source water is no longer hot enough.</description>
		<designationCategory>Temperature</designationCategory>
		<graphicData>
			<texPath>RealRim/Things/Building/SmartMixingValve</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<costList>
			<Steel>15</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<researchPrerequisites>
			<li>RealRim_SmartMixingValve</li>
		</researchPrerequisites>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>5</basePowerConsumption>
			</li>
			<li Class="RealRim.WaterAndPumps.CompProperties_FluidNode">
				<networks>
					<li>Heating</li>
				</networks>
				<valve>true</valve>
				<transfer_only>true</transfer_only>
			</li>
			<li Class="RealRim.WaterAndPumps.CompProperties_TargetTemperature">
				<default_temperature_c>35</default_temperature_c>
				<minimum_temperature_c>5</minimum_temperature_c>
				<maximum_temperature_c>85</maximum_temperature_c>
			</li>
			<li Class="RealRim.WaterAndPumps.CompProperties_SmartMixingValve">
				<maximum_transfer_kw>12</maximum_transfer_kw>
			</li>
		</comps>
	</ThingDef>
</Defs>
