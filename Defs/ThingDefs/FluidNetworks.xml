	<ThingDef ParentName="RealRim_FluidLayerConnectorBase">
		<defName>RealRim_FreshWaterLayerConnector</defName>
		<label>fresh-water layer connector</label>
		<description>Connects fresh-water pipes on any layer in adjacent tiles, linking those layers into one fresh-water network.</description>
		<designationCategory>Hygiene</designationCategory>
		<uiIconPath>RealRim/UI/FluidLayerFreshWater</uiIconPath>
		<researchPrerequisites><li>Plumbing</li></researchPrerequisites>
		<comps><li Class="RealRim.WaterAndPumps.CompProperties_FluidNode"><networks><li>FreshWater</li></networks><layer_connector>true</layer_connector></li></comps>
	</ThingDef>
	<ThingDef ParentName="RealRim_FluidLayerConnectorBase">
		<defName>RealRim_HotWaterLayerConnector</defName>
		<label>hot-water layer connector</label>
		<description>Connects hot-water pipes on any layer in adjacent tiles, linking those layers into one domestic hot-water network.</description>
		<designationCategory>Hygiene</designationCategory>
		<uiIconPath>RealRim/UI/FluidLayerHotWater</uiIconPath>
		<researchPrerequisites><li>Plumbing</li></researchPrerequisites>
		<comps><li Class="RealRim.WaterAndPumps.CompProperties_FluidNode"><networks><li>HotWater</li></networks><layer_connector>true</layer_connector></li></comps>
	</ThingDef>
	<ThingDef ParentName="RealRim_FluidLayerConnectorBase">
		<defName>RealRim_HeatingLayerConnector</defName>
		<label>heating-water layer connector</label>
		<description>Connects heating-water pipes on any layer in adjacent tiles, linking those layers into one heating-water network.</description>
		<designationCategory>Temperature</designationCategory>
		<uiIconPath>RealRim/UI/FluidLayerHeating</uiIconPath>
		<researchPrerequisites><li>CentralHeating</li></researchPrerequisites>
		<comps><li Class="RealRim.WaterAndPumps.CompProperties_FluidNode"><networks><li>Heating</li></networks><layer_connector>true</layer_connector><virtual_heat_buffer_liters_per_m>2</virtual_heat_buffer_liters_per_m></li></comps>
	</ThingDef>
	<ThingDef ParentName="RealRim_FluidLayerConnectorBase">
		<defName>RealRim_WasteWaterLayerConnector</defName>
		<label>waste-water layer connector</label>
		<description>Connects waste-water pipes on any layer in adjacent tiles, linking those layers into one waste-water network.</description>
		<designationCategory>Hygiene</designationCategory>
		<uiIconPath>RealRim/UI/FluidLayerWasteWater</uiIconPath>
		<researchPrerequisites><li>Plumbing</li></researchPrerequisites>
		<comps><li Class="RealRim.WaterAndPumps.CompProperties_FluidNode"><networks><li>WasteWater</li></networks><layer_connector>true</layer_connector></li></comps>
	</ThingDef>
	<ThingDef ParentName="RealRim_FluidLayerConnectorBase">
		<defName>RealRim_CoolantLayerConnector</defName>
		<label>coolant layer connector</label>
		<description>Connects air-con coolant pipes on any layer in adjacent tiles, linking those layers into one coolant network.</description>
		<designationCategory>Temperature</designationCategory>
		<uiIconPath>RealRim/UI/FluidLayerCoolant</uiIconPath>
		<researchPrerequisites><li>MultiSplitAirCon</li></researchPrerequisites>
		<comps><li Class="RealRim.WaterAndPumps.CompProperties_FluidNode"><networks><li>Coolant</li></networks><layer_connector>true</layer_connector></li></comps>
	</ThingDef>

	<ThingDef ParentName="RealRim_FluidValveBase">
		<defName>RealRim_SmartMixingValve</defName>
		<label>smart mixing valve</label>
		<description>A powered thermostatic hydronic mixing valve for heating-water circuits. It keeps two adjacent heating circuits separate and draws heat from the hotter source side into the receiving side. It can either regulate the receiving circuit by target water temperature or monitor its own room and open only while that room is below the selected room temperature.</description>
		<designationCategory>Temperature</designationCategory>
		<graphicData>
			<texPath>RealRim/Things/Building/SmartMixingValve</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<costList>
			<Steel>15</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<researchPrerequisites>
			<li>RealRim_SmartMixingValve</li>
		</researchPrerequisites>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>5</basePowerConsumption>
			</li>
			<li Class="RealRim.WaterAndPumps.CompProperties_FluidNode">
				<networks>
					<li>Heating</li>
				</networks>
				<valve>true</valve>
				<transfer_only>true</transfer_only>
			</li>
			<li Class="RealRim.WaterAndPumps.CompProperties_SmartMixingValve">
				<maximum_transfer_kw>12</maximum_transfer_kw>
				<default_water_temperature_c>35</default_water_temperature_c>
				<minimum_water_temperature_c>5</minimum_water_temperature_c>
				<maximum_water_temperature_c>85</maximum_water_temperature_c>
				<default_room_temperature_c>21</default_room_temperature_c>
				<minimum_room_temperature_c>5</minimum_room_temperature_c>
				<maximum_room_temperature_c>35</maximum_room_temperature_c>
			</li>
		</comps>
	</ThingDef>
</Defs>
