<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationConditional">
				<xpath>Defs/DesignationCategoryDef[defName="Hygiene"]/specialDesignatorClasses</xpath>
				<nomatch Class="PatchOperationAdd">
					<xpath>Defs/DesignationCategoryDef[defName="Hygiene"]</xpath>
					<value>
						<specialDesignatorClasses />
					</value>
				</nomatch>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/DesignationCategoryDef[defName="Hygiene"]/specialDesignatorClasses</xpath>
				<value>
					<li>RealRim.WaterAndPumps.Designator_SelectFreshWaterLayer</li>
					<li>RealRim.WaterAndPumps.Designator_SelectHotWaterLayer</li>
					<li>RealRim.WaterAndPumps.Designator_SelectWasteWaterLayer</li>
				</value>
			</li>
			<li Class="PatchOperationConditional">
				<xpath>Defs/DesignationCategoryDef[defName="Temperature"]/specialDesignatorClasses</xpath>
				<nomatch Class="PatchOperationAdd">
					<xpath>Defs/DesignationCategoryDef[defName="Temperature"]</xpath>
					<value>
						<specialDesignatorClasses />
					</value>
				</nomatch>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/DesignationCategoryDef[defName="Temperature"]/specialDesignatorClasses</xpath>
				<value>
					<li>RealRim.WaterAndPumps.Designator_SelectHeatingLayer</li>
					<li>RealRim.WaterAndPumps.Designator_SelectCoolantLayer</li>
				</value>
			</li>
		</operations>
	</Operation>
</Patch>
